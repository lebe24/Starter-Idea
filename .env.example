# App URL (used by local scripts)
NEXT_PUBLIC_APP_URL=http://127.0.0.1:3000

# Anthropic API key (required for AI validation/chat endpoints)
ANTHROPIC_API_KEY=

# GitHub integration token (optional, enables GitHub API data)
GITHUB_TOKEN=

# Product Hunt auth options (set either token or client credentials)
PRODUCT_HUNT_TOKEN=
PH_TOKEN=
PH_API_KEY=

PRODUCT_HUNT_CLIENT_ID=
PRODUCT_HUNT_CLIENT_SECRET=
PH_CLIENT_ID=
PH_CLIENT_SECRET=
PH_API_SECRET=
